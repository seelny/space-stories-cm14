ent-RMCWeaponRifleM54CWhiteNoLock = { ent-RMCWeaponRifleM54CSemiStripped }
    .desc = Винтовка M41А Mk2 с логотипом Вестон-Ямада, нанесенным на ствольную коробку. Используется преимущественно службами корпоративной безопасности Вестон-Ямада и имеет невзрачную корпоративную белую окраску.
    .suffix = Corporate, No UGL, No ID lock
ent-RMCWeaponRifleM54CWhiteCommando = { ent-RMCWeaponRifleM54CWhite }
