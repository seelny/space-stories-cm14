ent-RMCBaseStorageBag = storage bag
    .desc = A foldable storage container.
ent-CMBodyBag = мешок для трупов
    .desc = Сложенный мешок, предназначенный для хранения и транспортировки трупов.
ent-CMBodyBagFolded = { ent-CMBodyBag }
    .suffix = Сложенный
    .desc = { ent-CMBodyBag.desc }
ent-RMCBodyBagOpen = { ent-CMBodyBag }
    .suffix = Открытый
    .desc = { ent-CMBodyBag.desc }
ent-CMStasisBag = стазис-мешок
    .desc = Сложенная сумка многоразового использования, предназначенная для предотвращения дополнительных повреждений пассажира.
ent-CMStasisBagFolded = { ent-CMStasisBag }
    .suffix = Сложенный
    .desc = { ent-CMStasisBag.desc }
ent-RMCStasisBagUsed = использованный стазисный мешок
    .desc = Она была разорвана. Вам нужно будет найти машину, способную его переработать.
    .suffix = мусор
ent-RMCThermalTarpV2 = реактивный термобрезент V2
    .desc = Термобрезент, используемый некоторыми пехотинцами КМП США. Этот обновленный плащ способен почти безупречно сливаться с окружающей средой, при условии, что он может должным образом собирать данные после развертывания. Плащ способен скрывать тепловую сигнатуру носителя.
ent-RMCThermalTarpV2Folded = { ent-RMCThermalTarpV2 }
    .suffix = сложенный
    .desc = { ent-RMCThermalTarpV2.desc }
ent-RMCThermalTarp = реактивный термобрезент V3
    .desc = Более компактная и улучшенная версия термобрезента V2, предназначенная в первую очередь для транспортировки умерших или раненых морских пехотинцев. Он обладает более совершенной технологией маскировки, чем предыдущие модели, что позволяет ему маскироваться в большей степени и быстрее, но использовать его можно только при специальной подготовке.
ent-RMCThermalTarpFolded = { ent-RMCThermalTarp }
    .suffix = Сложенный
    .desc = { ent-RMCThermalTarp.desc }
