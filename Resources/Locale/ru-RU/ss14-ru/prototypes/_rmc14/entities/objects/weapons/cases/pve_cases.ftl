    .suffix = { ent-RMCPVECaseM42A2.suffix }
ent-RMCPVECaseM5SPR2 = M5SPR2 battle rifle case
    .desc = A large case for storing an M5SPR2, a modified We-Ya PMC battle rifle equipped with HV-P Rounds.
    .suffix = { ent-RMCPVECaseM5SPR.suffix }
ent-RMCPVECaseType64 = Type 64 smg case
    .desc = A heavy case for storing a Type 64 submachine-gun, the standard SMG of the Socialist Progressive Peoples.
    .suffix = { ent-RMCBasePVEEquipmentCase.suffix }
ent-RMCPVECaseType88 = Type 88 DMR case
