ent-RMCVisorBase = { ent-BaseItem }
    .desc = { ent-BaseItem.desc }
ent-RMCVisorNightVision = оптический прибор ночного видения
    .desc = Вставляемый визор HUD в стандартный шлем КМП США. Этот тип дает возможность ночного видения и является стандартным для подразделений с регулярным финансированием.
ent-RMCVisorMedical = базовый медицинский визор
    .desc = Встраиваемый HUD-визор для стандартного шлема КМП США. Этот тип обеспечивает проекционный дисплей, который показывает данные о состоянии здоровья ближайших гуманоидов.
ent-RMCVisorMedicalAdvanced = продвинутый медицинский визор
    .desc = Встраиваемый HUD-визор для стандартного шлема КМП США. Этот тип обеспечивает проекционный дисплей, который показывает данные о состоянии здоровья ближайших гуманоидов и результаты исследований.
ent-RMCVisorMedicalAdvancedIntegrated = { ent-RMCVisorMedicalAdvanced }
    .desc = { ent-RMCVisorMedicalAdvanced.desc }
    .suffix = Встроенный
ent-RMCVisorWelding = сварочный визор
    .desc = Встраиваемый HUD-визор для стандартного шлема КМП США. Этот тип защищает глаза от сварочных работ.
ent-RMCVisorWeldingIntegrated = { ent-RMCVisorWelding }
    .desc = { ent-RMCVisorWelding.desc }
    .suffix = Встроенный
ent-RMCVisorSquad = отрядный визор
    .desc = Встраиваемый HUD-визор для стандартного шлема КМП США. Этот тип обеспечивает проекционный дисплей, показывающий данные об отрядах морпехов.
ent-RMCVisorSquadIntegrated = { ent-RMCVisorSquad }
    .desc = { ent-RMCVisorSquad.desc }
    .suffix = Встроенный
ent-RMCVisorPilotBlack = MK30 black flight visor
    .desc = A standard issue snap-on visor used by UNMC dropship pilots. Polarized to reduce glare and protect the eyes during atmospheric re-entry and orbital deployment.
ent-RMCVisorPilotDarkblue = MK30 dark blue flight visor
    .desc = { ent-RMCVisorPilotBlack.desc }
ent-RMCVisorPilotLightblue = MK30 light blue flight visor
    .desc = { ent-RMCVisorPilotBlack.desc }
ent-RMCVisorPilotPurple = MK30 purple flight visor
    .desc = { ent-RMCVisorPilotBlack.desc }
ent-RMCVisorPilotRed = MK30 red flight visor
    .desc = { ent-RMCVisorPilotBlack.desc }
ent-RMCVisorPilotYellow = MK30 yellow flight visor
    .desc = { ent-RMCVisorPilotBlack.desc }
