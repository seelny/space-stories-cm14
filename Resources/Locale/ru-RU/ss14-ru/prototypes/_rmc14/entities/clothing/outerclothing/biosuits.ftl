ent-RMCBaseBioSuit = { ent-RMCBaseArmor }
    .desc = { ent-RMCBaseArmor.desc }
ent-RMCSuitBioGeneral = биокостюм
    .desc = Костюм, защищающий от биологического заражения.
    .suffix = Стандартный, RMC
ent-RMCArmorFirefighter = огнезащитный костюм PT-LT
    .desc = "PyroTex LT" — современный лёгкий огнезащитный костюм, разработанный компанией "Fujin". Он обеспечивает защиту от огня и жара, а также некоторую защиту от тупых травм.
ent-RMCArmorSPPFirefighter = пожарная куртка T-20
    .desc = Прочная, простая в использовании огнестойкая куртка, выдаваемая промышленным и аварийным бригадам СПН. Разработана на основе PyroTex LT, но с использованием более дешёвых материалов отечественного производства. Обеспечивает базовую защиту от тепла и мусора, но тяжелее и менее удобна.
ent-RMCSuitBioWeYa = биокостюм ВеЯ-TSS MK I
    .desc = "Вестон-Ямада TerraScientia биокостюм MK I". Современный лёгкий биокостюм собственной разработки Вестон-Ямада. Защищает от биологического заражения.
    .suffix = Стандартный, ВеЯ
