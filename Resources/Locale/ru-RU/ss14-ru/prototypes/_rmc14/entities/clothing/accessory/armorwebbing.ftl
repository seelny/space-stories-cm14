ent-RMCArmorWebbingBase = бронеразгрузка
    .desc = { ent-BaseItem.desc }
    .suffix = PVE
ent-RMCArmorWebbingDrum = бронеразгрузка для барабанных магазинов
    .desc = Коричневая разгрузочная система, оснащенная парой больших подсумков, способных вмещать барабанные магазины большой емкости и другие крупные магазины.
    .suffix = { ent-RMCArmorWebbingBase.suffix }
ent-RMCArmorWebbingMag = бронеразгрузка для магазинов
    .desc = Коричневая разгрузочная система, оснащенная парой больших подсумков, способных вмещать магазины.
    .suffix = { ent-RMCArmorWebbingBase.suffix }
ent-RMCArmorWebbingGrenade = бронеразгрузка для гранат
    .desc = Коричневая разгрузочная система с несколькими небольшими карманами, предназначенными для переноски 6 гранат.
    .suffix = { ent-RMCArmorWebbingBase.suffix }
ent-RMCArmorWebbingPouch = бронеразгрузка
    .desc = Коричневая разгрузочная система с несколькими небольшими карманами, предназначенными для переноски различных мелких предметов.
    .suffix = { ent-RMCArmorWebbingBase.suffix }
ent-RMCArmorWebbingShell = бронеразгрузка для дроби
    .desc = Коричневая разгрузочная система с несколькими петлями, предназначенными для удержания незакрепленных патронов для дробовика.
    .suffix = { ent-RMCArmorWebbingBase.suffix }
ent-RMCArmorWebbingDrumRCM = MOLS drum armor webbing
    .desc = A set of L1 pattern MOLS webbing, modified so as to clip onto an L3-pattern Kestrel modular vest. Features a pair of large pouches capable of carrying high-capacity drums and other large magazines.
    .suffix = PVE, Royal
ent-RMCArmorWebbingMagRCM = MOLS magazine armor webbing
    .desc = A set of L1 pattern MOLS webbing, modified so as to clip onto an L3-pattern Kestrel modular vest. Features a set of four magazine pouches.
    .suffix = PVE, Royal
ent-RMCArmorWebbingGrenadeRCM = MOLS grenade armor webbing
    .desc = A set of L1 pattern MOLS webbing, modified so as to clip onto an L3-pattern Kestrel modular vest. Features an array of small pouches, capable of holding up to 6 grenades.
    .suffix = PVE, Royal
ent-RMCArmorWebbingPouchRCM = MOLS general armor webbing
    .desc = A set of L1 pattern MOLS webbing, modified so as to clip onto an L3-pattern Kestrel modular vest. Features several small pouches, capable of carrying assorted small items.
    .suffix = PVE, Royal
ent-RMCArmorWebbingShellRCM = MOLS shell armor webbing
    .desc = A set of L1 pattern MOLS webbing, modified so as to clip onto an L3-pattern Kestrel modular vest. Features a number of loops designed to hold loose shotgun shells.
    .suffix = PVE, Royal
