ent-CMChairComfyAlpha = { ent-CMChairComfy }
    .desc = Простой стул, прикрепленный к полу. Обитый скрипучей и слишком жесткой искусственной кожей, неровно выкрашенный в красный цвет отряда "Альфа". Только для самых смелых и свежих новобранцев КМП США.
    .suffix = Альфа
ent-CMChairComfyBravo = { ent-CMChairComfy }
    .desc = Простой стул, прикрепленный к полу. Покрыт скрипучей и слишком жесткой искусственной кожей, неравномерно окрашенной в коричневый цвет отряда "Браво". Убедительная защита от вражеского вторжения со всех сторон.
    .suffix = Браво
ent-CMChairComfyCharlie = { ent-CMChairComfy }
    .desc = Простой стул, прикрепленный к полу. Покрыт скрипучей и слишком жесткой искусственной кожей, неравномерно окрашенной в фиолетовый цвет отряда "Чарли". Чувствует себя не в своей тарелке без полноценного завтрака.
    .suffix = Чарли
ent-CMChairComfyDelta = { ent-CMChairComfy }
    .desc = Простой стул, прикрепленный к полу. Обтянут скрипучей и слишком жесткой искусственной кожей, неравномерно окрашенной в синий цвет отряда "Дельта". Этот стул, скорее всего, первым вступит в бой и первым умрет.
    .suffix = Дельта
