    .desc = Some off-branded gun rack. This one has been modified slightly to fit 2 LPO80 Incinerator Units, while still meeting the SPP standards for firearm storage.
    .suffix = LPO80 Incinerator, Empty
ent-RMCGunRackLPO80IncineratorFilled = { ent-RMCGunRackLPO80IncineratorEmpty }
